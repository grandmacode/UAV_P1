% =========================================================================



data = readtable('2024-04-04_log07.csv');
t_log1 = (data.timestamp - data.timestamp(1)) / 1000; % Tempo em segundos

% Dados para os diferentes Ângulos de Euler
phi = data.stateEstimate_roll;   
theta = data.stateEstimate_pitch;
