% Dados para os diferentes inputs
m1 = data.motor_m1; m2 = data.motor_m2; m3 = data.motor_m3; m4 = data.motor_m4;
u1 = m1 + m2 + m3 + m4;          % Thrust
u2 = -m1 - m2 + m3 + m4;         % Roll Torque
u3 = m1 - m2 - m3 + m4;          % Pitch Torque
u4 = m1 - m2 + m3 - m4;          % Yaw Torque


figure('Name', 'Figura: Angulos de Euler', 'Color', 'w');

subplot(3,1,1);
plot(t_log1, phi, 'b', 'LineWidth', 1);
ylabel('\phi [deg]'); title('Roll (\lambda_1)');
