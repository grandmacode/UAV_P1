%% ========================================================================
% Identificação dos modelos =>  2.3
% =========================================================================

% 1. Preparação dos Dados
t_log = (data.timestamp - data.timestamp(1)) / 1000;
Ts = mean(diff(t_log));

% Saídas (Posições em metros)
px = data.stateEstimate_x;
py = data.stateEstimate_y;
pz = data.stateEstimate_z;

% Entradas - Conversão para Radianos
theta_rad = data.stateEstimate_pitch * (pi/180); 
phi_rad = data.stateEstimate_roll * (pi/180);


u1_raw = data.motor_m1 + data.motor_m2 + data.motor_m3 + data.motor_m4;
u1_norm = u1_raw / max(u1_raw); 


dataX = iddata(px, theta_rad, Ts);
dataY = iddata(py, phi_rad, Ts);
dataZ = iddata(pz, u1_norm, Ts);


sysX = tfest(dataX, 2, 0); 
sysY = tfest(dataY, 2, 0); 
sysZ = tfest(dataZ, 2, 0); 


fprintf('\n--- FUNÇÕES DE TRANSFERÊNCIA IDENTIFICADAS ---\n');

fprintf('\nG_theta_px (Eixo X - Rad p/ Metros):\n');
G_theta_px = tf(sysX)

fprintf('\nG_phi_py (Eixo Y - Rad p/ Metros):\n');
G_phi_py = tf(sysY)

fprintf('\nG_T_pz (Eixo Z - Thrust Norm p/ Metros):\n');
G_T_pz = tf(sysZ)



% Eixo X
figure('Name', 'Identificação Eixo X: Input vs Output', 'Color', 'w');
subplot(2,1,1);
plot(t_log, theta_rad, 'r'); ylabel('\theta [rad]'); 
title('Input: Pitch Angle'); grid on;
subplot(2,1,2);
plot(t_log, px, 'b'); ylabel('p_x [m]'); 
xlabel('Tempo [s]'); title('Output: Position X'); grid on;

% Eixo Y
figure('Name', 'Identificação Eixo Y: Input vs Output', 'Color', 'w');
subplot(2,1,1);
plot(t_log, phi_rad, 'g'); ylabel('\phi [rad]'); 
title('Input: Roll Angle'); grid on;
subplot(2,1,2);
plot(t_log, py, 'b'); ylabel('p_y [m]'); 
xlabel('Tempo [s]'); title('Output: Position Y'); grid on;

% Eixo Z
figure('Name', 'Identificação Eixo Z: Input vs Output', 'Color', 'w');
subplot(2,1,1);
plot(t_log, u1_norm, 'k'); ylabel('u_1 [Norm]'); 
title('Input: Thrust'); grid on;
subplot(2,1,2);
plot(t_log, pz, 'b'); ylabel('p_z [m]'); 
xlabel('Tempo [s]'); title('Output: Position Z'); grid on;


figure('Name', 'Identificação: Respostas ao Degrau', 'Color', 'w');
subplot(3,1,1);
step(sysX); title('Step Response: G_{\theta,p_x}(s) (Input: 1 rad)');
grid on;
subplot(3,1,2);
step(sysY); title('Step Response: G_{\phi,p_y}(s) (Input: 1 rad)');
grid on;
subplot(3,1,3);
step(sysZ); title('Step Response: G_{T,p_z}(s) (Input: Thrust Unitário)');
grid on;

%% ========================================================================
% Funções de Transferência
% ========================================================================
fprintf('\n--- Funções de Transferência Identificadas (2.ª Ordem) ---\n');

fprintf('\nEixo X (Entrada: pitch [deg] -> Saída: px [m]):\n');
G_theta_px = tf(sysX)

fprintf('\nEixo Y (Entrada: roll [deg] -> Saída: py [m]):\n');
