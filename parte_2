subplot(3,1,2);
plot(t_log, theta, 'r', 'LineWidth', 1);
ylabel('\theta [deg]'); title('Pitch (\lambda_2)');
grid on; xlim([t_log1(1) t_log1(end)]);

subplot(3,1,3);
plot(t_log, yaw, 'Color', [0.49 0.18 0.56], 'LineWidth', 1);
ylabel('\psi [deg]'); title('Yaw (\lambda_3)');
xlabel('Tempo [s]');
grid on; xlim([t_log1(1) t_log1(end)]);

