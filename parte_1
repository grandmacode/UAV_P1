px_theta_coupling = -vx0 * sin(theta_e)

A_pitch_OP2 = [0,1,0,0;  0,0,0,0;  px_theta_coupling,0,0,1;  alpha,0,0,-kd_m];
%B_pitch_OP2 = [0;  1/Jy;  0;  0];
B_pitch_OP2 = [0,0;  1/Jy,0;   0,0;   0,-sin(theta_e)/m]; % drone = inclinado para a frente => + T ;  vai pra frente (x) tmb
