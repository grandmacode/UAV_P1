%% ========================================================================
% FUNÇÕES AUXILIARES
% ========================================================================

function R = rotation_matrix_euler(phi, theta, psi)
    % Matriz de Rotação Z-Y-X: leva vetor do inercial para o corpo
    c_phi = cos(phi);   s_phi = sin(phi);
    c_the = cos(theta); s_the = sin(theta);
    c_psi = cos(psi);   s_psi = sin(psi);

    R = [c_psi*c_the,  c_psi*s_the*s_phi - s_psi*c_phi,  c_psi*s_the*c_phi + s_psi*s_phi;
         s_psi*c_the,  s_psi*s_the*s_phi + c_psi*c_phi,  s_psi*s_the*c_phi - c_psi*s_phi;
        -s_the,         c_the*s_phi,                       c_the*c_phi];
end

function E = euler_kinematics_matrix(phi, theta)
    %omega_body -> euler_dot
    c_phi = cos(phi); s_phi = sin(phi);
    c_the = cos(theta); t_the = tan(theta);

    E = [1,  s_phi*t_the,  c_phi*t_the;
         0,  c_phi,       -s_phi;
         0,  s_phi/c_the,  c_phi/c_the];
end

function str = yesno(val)
    if val
        str = 'SIM';
    else
        str = 'NAO';
    end
end


function str = format_eigs(ev)
    % Formata vetor de eigenvalores como string compacta
    parts = arrayfun(@(x) sprintf('%.4f', x), ev, 'UniformOutput', false);
    str = strjoin(parts, '  ');
end
