fprintf('  ue = [%.6f; 0; 0; 0]\n\n', T_flight);


disp('--- 1.7 (OP2): Horizontal Flight Linearization ---');

% Coeficientes uteis para a linearizacao
alpha = -(T_flight/m) * cos(theta_e);  % d(vx_I_dot)/d(delta_theta)
beta  =  (T_flight/m) * sin(theta_e);  % d(vz_I_dot)/d(delta_theta)  [valor pequeno]

