clear; clc; close all;

%% ========================================================================
% DEFINIÇÃO DE PARÂMETROS
% ========================================================================

% parâmetros físicos do drone
m = 0.027;               % @ 1.1
g = 9.81;                % @ 1.2
k_drag = 0.01;           % @ 1.2 => coeficiente de arrasto aerodinâmico [N/(m/s)]
kd_m  = k_drag / m;                    % coeficiente de amortecimento por arrasto [1/s]

% @ 1.1 => matriz de inércia (J) => [kg*m^2]
Jx = 1.4e-5;
Jy = 1.4e-5;
Jz = 2.1e-5;
J  = diag([Jx, Jy, Jz]);

% parâmetros dos motores e aerodinâmica
cT = 3.16e-10;  % coeficiente de empuxo (T = cT * w^2)
tau_m = 0.05;      % @ 1.5 => constante de tempo do motor [s]
arm_length = 0.046;     % [m]
torque_factor = 0.01;    % [Nm/N]

% @ 1.4: configuração geometrica e matriz de alocação
L = arm_length;
c = torque_factor;
d = L * sin(pi/4);  % configuração em X

% mapeamento [T1;T2;T3;T4] => [T_total; nx; ny; nz]
u_map = [ 1,  1,  1,  1;
         -d, -d,  d,  d;
         -d,  d,  d, -d;
          c, -c,  c, -c];



%% ========================================================================
% Non-Linear Model Simulation (1.5)
% ========================================================================

time_step = 0.01;
sim_time = 5;
n_steps = sim_time / time_step;

% Velocidade de hover para os motores
w_hover = sqrt((m*g/4) / cT);

% Estado inicial: parado a 10 m de altitude
initial_state = zeros(16, 1);
initial_state(3) = 10;  % altitude inicial [m]
initial_state(13:16) = w_hover; % motores já à velocidade de hover

% Comando: 5% acima do hover para o drone subir ligeiramente
u_cmd = ones(4,1) * w_hover * 1.05;

time = (0:n_steps-1) * time_step;
states = zeros(16, n_steps);
states(:,1) = initial_state;

for k = 1:n_steps-1
    p = states(1:3, k);
    v = states(4:6, k);
    phi = states(7, k);
    theta = states(8, k);
    psi = states(9, k);
    omega = states(10:12,k);
    w_motor = states(13:16,k);

    % Dinâmica dos motores (1ª ordem)
    w_motor_dot = (u_cmd - w_motor) / tau_m;

    % Forças de cada rotor
    T_rotors = cT * w_motor.^2;

    % Alocação de controlo
    ctrl_vec = u_map * T_rotors;
    T_total = ctrl_vec(1);
    n_p = ctrl_vec(2:4);

    % Força de propulsão no corpo
    fp_body = [0; 0; T_total];

    % Gravidade e arrasto no corpo
    R_BI = rotation_matrix_euler(phi, theta, psi);
    fg_body = R_BI' * [0; 0; -m*g];
    fa_body = -k_drag * v;

    % Força total no corpo
    f_total = fg_body + fa_body + fp_body;

    % Dinâmica rotacional (Euler) e translacional (Newton)
    omega_dot = J \ (n_p - cross(omega, J*omega));
    v_dot = f_total/m - cross(omega, v);

    % Cinemática dos ângulos de Euler
    E = euler_kinematics_matrix(phi, theta);
    euler_dot  = E * omega;

    % Integração numérica 
    states(4:6,  k+1) = v + v_dot * time_step;
    states(10:12,k+1) = omega + omega_dot * time_step;
    states(7:9,  k+1) = states(7:9,k) + euler_dot * time_step;
    states(13:16,k+1) = w_motor + w_motor_dot* time_step;

    v_inertial = R_BI * states(4:6, k+1);
    states(1:3,  k+1) = p + v_inertial * time_step;
end

% --- Plots da Simulação ---
figure('Name', '1.5: Simulacao Nao-Linear (ENU)', 'Position', [100, 100, 1000, 700]);

subplot(2,2,1);
plot3(states(1,:), states(2,:), states(3,:), 'b-', 'LineWidth', 1.5);
xlabel('X (Este) [m]'); ylabel('Y (Norte) [m]'); zlabel('Z (Altitude) [m]');
title('Trajetoria 3D (ENU)'); grid on; view(45,30); hold on;
plot3(states(1,1),   states(2,1),   states(3,1),   'go', 'MarkerFaceColor','g', 'DisplayName','Inicio');
plot3(states(1,end), states(2,end), states(3,end), 'ro', 'MarkerFaceColor','r', 'DisplayName','Fim');
legend('Location','Best');

subplot(2,2,2);
plot(time, states(3,:), 'b-', 'LineWidth', 1.5);
xlabel('Tempo [s]'); ylabel('Altitude (Z) [m]');
title('Altitude vs Tempo'); grid on;

subplot(2,2,3);
plot(time, states(4,:),'r-', time, states(5,:),'g-', time, states(6,:),'b-', 'LineWidth', 1.5);
xlabel('Tempo [s]'); ylabel('Velocidade [m/s]');
title('Velocidade Linear (corpo)'); legend('Vx','Vy','Vz'); grid on;

subplot(2,2,4);
plot(time, states(13,:),'r-', time, states(14,:),'g--', ...
     time, states(15,:),'b-', time, states(16,:),'k--', 'LineWidth', 1.5);
